# OpenClaw Integration Environment Variables
# Copy this to .env and fill in the values

# Feature flag - set to 'true' to enable OpenClaw integration
HAPPY_OPENCLAW_ENABLED=false

# OpenClaw Gateway URL (where the Channel Plugin connects)
# For local development, use the default Gateway address
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Gateway authentication token (obtained from OpenClaw config)
# This token is encrypted when stored in the database
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Shared secret for HMAC signing (Plugin ↔ Server communication)
# Generate a secure random string: openssl rand -hex 32
OPENCLAW_CHANNEL_SECRET=generate-a-secure-random-secret-here
